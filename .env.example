# Flask API Configuration
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# India API Port
INDIA_API_PORT=5001

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_SECOND=10

# Logging
LOG_LEVEL=INFO
